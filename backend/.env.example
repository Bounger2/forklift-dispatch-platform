SECRET_KEY=change-me-in-production
JWT_EXP_SECONDS=86400

# 本地演示可不设置 DATABASE_URL，默认使用 backend/instance/dispatch_dev.db。
# 生产/联调 MySQL 示例：
DATABASE_URL=mysql+pymysql://dispatch_user:dispatch_password@127.0.0.1:3306/forklift_dispatch?charset=utf8mb4

SIMULATION_ENABLED=false
SIMULATION_STEP_SECONDS=5
CORS_ALLOW_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:8088,http://localhost:8088

# 企业微信推送。未配置或 WECOM_DRY_RUN=true 时只写入 wecom_messages 表。
WECOM_DRY_RUN=true
WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_SECRET=
